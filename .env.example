# Galax-Graphy Environment Variables

# The password required by the single password gate on frontend load.
# In development, if left blank or unset, this will default to "admin".
VITE_APP_PASSWORD=admin

# Supabase integration credentials (optional, falls back to LocalStorage if empty)
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
